# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments and local configuration
.venv/
venv/
env/
.env
.env.*
!.env.example

# Packaging and build output
build/
dist/
*.egg-info/

# Test and analysis caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs and generated experiment artifacts
*.log
runs/*
!runs/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
